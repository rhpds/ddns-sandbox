# Copy to /etc/bind-key-api/bind-key-api.env and chmod 600.
# systemd EnvironmentFile format: KEY=value (no export, no quotes unless needed).

# Required — long random secret for Authorization: Bearer
BIND_KEY_API_AUTH_TOKEN=change-me-to-a-long-random-secret-min-16-chars

# Listen address (recommended: loopback + reverse proxy)
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8080

# rndc authentication (typical on Debian BIND)
BIND_KEY_API_RNDC_EXTRA_ARGS=["-k","/etc/bind/rndc.key"]

# TSIG key file and zone cleanup (set paths to match your server)
# BIND_KEY_API_BIND_KEYS_PATH=/etc/named.dyn.redhatworkshops.io.key
# BIND_KEY_API_ZONE_NAME=dyn.redhatworkshops.io
# BIND_KEY_API_ZONE_FILE_PATH=/var/named/dyn.redhatworkshops.io.zone
# BIND_KEY_API_DELETE_ZONE_RRSETS_ON_KEY_DELETE=true
# BIND_KEY_API_FREEZE_ZONE_BEFORE_CLEANUP=false
# BIND_KEY_API_NSUPDATE_PATH=/usr/sbin/nsupdate
