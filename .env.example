# Copy to .env for podman compose / docker compose (same directory as compose.yaml)

BIND_KEY_API_AUTH_TOKEN=change-me-to-a-long-random-secret-min-16-chars

# Paths and zone — must match your BIND layout (examples only; adjust for your server).
BIND_KEY_API_BIND_KEYS_PATH=/etc/named.dyn.redhatworkshops.io.key
BIND_KEY_API_ZONE_NAME=dyn.redhatworkshops.io
BIND_KEY_API_ZONE_FILE_PATH=/var/named/dyn.redhatworkshops.io.zone

# Optional: delete client DNS names on key delete (requires zone settings above).
# BIND_KEY_API_DELETE_ZONE_RRSETS_ON_KEY_DELETE=true
